###############################################################################
#  Python – general                                                           #
###############################################################################

# Byte-code and interpreter artefacts
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

###############################################################################
#  Packaging / build                                                          #
###############################################################################
build/
dist/
wheels/
*.egg-info/
.eggs/
*.egg
*.whl

###############################################################################
#  Virtual-envs & tooling                                                     #
###############################################################################
.venv/
venv/
env/
ENV/
# Poetry keeps pyproject.toml & poetry.lock committed – do NOT ignore them

###############################################################################
#  PyInstaller                                                                #
###############################################################################
*.spec

###############################################################################
#  Testing & coverage artefacts                                               #
###############################################################################
.pytest_cache/
.hypothesis/
.coverage
coverage.xml
*.cover
htmlcov/

###############################################################################
#  Type-checker / lint caches                                                 #
###############################################################################
.mypy_cache/
.dmypy.json
__pydantic_schema_cache__/

###############################################################################
#  Logs, patches, temp files                                                  #
###############################################################################
*.log
*.tmp
*.temp
*.bak
*.orig
*.patch

# Logging directory (contains API requests/responses with sensitive data)
logs/
logs/**/*

###############################################################################
#  IDE / editor settings                                                      #
###############################################################################
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

###############################################################################
#  Jupyter notebooks checkpoints                                              #
###############################################################################
.ipynb_checkpoints/

###############################################################################
#  OS-specific cruft                                                          #
###############################################################################
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*~

###############################################################################
#  Secrets & local config                                                     #
###############################################################################
.env
.env.*
*.env

###############################################################################
#  Project-specific ignores                                                   #
###############################################################################

# Local data directories
data/

# Runtime outputs in output/ directory (but preserve output/archive/)
output/*.log
output/*.csv
output/*.json
output/*.tsv
output/*.xlsx
output/*.pdf
output/*.html

# Temporary spreadsheet backups
backups/

# Test run results (timestamped outputs from test execution)
tests/**/test_results_*.json
tests/**/test_output_*.json
tests/**/*_results_*.csv
tests/**/*.log

# Script-generated temporary outputs
scripts/**/output/
scripts/**/*.tmp.json
scripts/**/*.tmp.tsv
scripts/**/*.tmp.csv

# Post-publish smoke-test config (contains institution-specific identifiers)
scripts/post_publish/smoke_config.json

# FAISS / index binaries that may appear elsewhere
*.faiss
*.index

###############################################################################
#  Archive Strategy (What IS Tracked)                                        #
###############################################################################
# The following are intentionally TRACKED for documentation/reference:
# - output/archive/ - Historical execution artifacts and findings
# - tests/case_studies/*/POL-*_data.json - Reference POL data for workflows
# - tests/case_studies/*/archive/ - Preserved test results for comparison
# - tests/ directory itself - Organized test suite (unit/integration/case studies)
# - scripts/ directory - Investigation and cleanup utilities

###############################################################################
#  Babysitter orchestration (.a5c)                                            #
###############################################################################
# Node modules (dependencies)
.a5c/node_modules/

# Run-specific logs (but keep runs structure for process tracking)
.a5c/logs/

###############################################################################
#  Local-only research / scratch (never committed)                            #
###############################################################################
research/

###############################################################################
#  Babysitter — keep templates (.a5c/processes/), drop everything else        #
###############################################################################
.a5c/runs/
.a5c/cache/
.a5c/logs/
.a5c/inputs/
.a5c/inputs-phase-f.json
.a5c/.a5c/
.a5c/node_modules/
.a5c/package.json
.a5c/package-lock.json

###############################################################################
#  Claude Code / project-local agent settings                                 #
###############################################################################
.claude/settings.local.json
.claude/skills/

###############################################################################
#  Personal scratchpad / temp / backups (never commit)                        #
###############################################################################
backups/
*_tmp.html
*_tmp.md

###############################################################################
#  Local-only archive of removed branches/data (never commit)                 #
###############################################################################
archive/

###############################################################################
#  End                                                                        #
###############################################################################

*:Zone.Identifier

# Chunk-driven scaffolding: keep manifests + status + sandbox-tests (used by
# the regression-smoke runner), drop raw pytest output logs.
chunks/*/sandbox-test-output/
# Operator-supplied fixture values (user IDs, MMS IDs, vendor codes, etc.) live
# in test-data.json — NEVER commit these. Treated as PII / institution-internal.
chunks/*/test-data.json
# pr_open's per-chunk sidecar; stdout-of-shell-task workaround (see chunk-test.js).
chunks/*/_pr_open_result.json

# Reproducible byproducts of scripts/error_codes/fetch_domain_codes.py
# (fetched Alma swagger specs + extracted error-code reports). Regenerated
# on every fetch-swagger-codes step in the chunk pipeline.
scripts/error_codes/swagger_cache/
